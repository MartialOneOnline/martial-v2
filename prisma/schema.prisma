generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum Role {
  SUPERADMIN
  SCHOOL_OWNER
  INSTRUCTOR
  STUDENT
}

enum SchoolStatus {
  UNVERIFIED  // Imported from Vonsel, not confirmed
  CLAIMED     // Academy signed up and confirmed listing
  VERIFIED    // Stripe connected, fully active
  PARTNER     // Roger Gracie / Buchecha affiliated
  SUSPENDED
}

enum SchoolSource {
  VONSEL          // Imported via Vonsel CSV
  MANUAL          // Added by Superadmin
  SELF_REGISTERED // Academy registered themselves
}

enum PaymentMethod {
  STRIPE
  CASH
  BANK_TRANSFER
}

enum SchoolMemberRole {
  OWNER
  INSTRUCTOR
  STUDENT
  LEAD        // Interested but not yet a member
}

enum SchoolMemberStatus {
  ACTIVE
  INACTIVE
  PENDING
  ARCHIVED
}

enum ClaimStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum MembershipStatus {
  ACTIVE
  PAUSED
  CANCELLED
  EXPIRED
}

// ─────────────────────────────────────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String?
  phone          String?
  avatarUrl      String?
  supabaseAuthId String?  @unique @db.Uuid
  role           Role     @default(STUDENT)

  // School this user manages (if SCHOOL_OWNER or INSTRUCTOR)
  schoolId       String?
  school         School?  @relation("SchoolStaff", fields: [schoolId], references: [id])

  // Schools this user claimed ownership of
  claimedSchools School[] @relation("SchoolClaimer")

  // Bookings, memberships and reviews
  bookings       Booking[]
  memberships    Membership[]
  campBookings   CampBooking[]
  reviews        Review[]      // Reviews written by this user
  schoolMembers  SchoolMember[]
  schoolClaims   SchoolClaim[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("users")
}

// ─────────────────────────────────────────────────────────────────────────────
// DISCIPLINE
// ─────────────────────────────────────────────────────────────────────────────

model Discipline {
  id      String              @id @default(cuid())
  name    String              @unique // BJJ, MMA, Muay Thai, Boxing, Wrestling, Judo, Karate, etc.
  slug    String              @unique
  schools SchoolDiscipline[]

  @@map("disciplines")
}

model SchoolDiscipline {
  schoolId     String
  disciplineId String
  school       School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  discipline   Discipline @relation(fields: [disciplineId], references: [id])

  @@id([schoolId, disciplineId])
  @@map("school_disciplines")
}

// ─────────────────────────────────────────────────────────────────────────────
// SCHOOL
// ─────────────────────────────────────────────────────────────────────────────

model School {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  status      SchoolStatus @default(UNVERIFIED)
  source      SchoolSource @default(SELF_REGISTERED)

  // Location
  country     String?
  city        String?
  address     String?
  postcode    String?
  lat         Float?
  lng         Float?

  // Contact
  phone       String?
  email       String?
  website     String?

  // Social
  instagram   String?
  facebook    String?
  youtube     String?
  tiktok      String?

  // Profile
  description String?
  tagline     String?   // Short one-liner: "Elite BJJ training in the heart of Málaga"
  logoUrl     String?
  coverUrl    String?
  photos      String[]  // Array of image URLs (Cloudinary)

  // Public listing extras
  priceFrom       Float?    // Lowest monthly price shown on listing card
  hasFreeTrialCls Boolean   @default(false)
  facilities      String[]  // ["Tatami mats 200m²", "Showers", "Pro shop", "Parking"]
  foundedYear     Int?
  totalStudents   Int?      // Manually set by school owner (approximate)

  // Affiliation
  affiliationName String?   // "Roger Gracie Academy", "Checkmat", "Alliance"
  affiliationUrl  String?

  // Google / Vonsel data
  googleRating   Float?
  googleReviews  Int?
  googlePlaceId  String?

  // Stripe
  stripeAccountId String?

  // Ownership
  claimedBy      User?            @relation("SchoolClaimer", fields: [claimedById], references: [id])
  claimedById    String?
  claimedAt      DateTime?

  // Relations
  staff           User[]             @relation("SchoolStaff")
  disciplines     SchoolDiscipline[]
  classes         Class[]
  memberships     Membership[]
  camps           Camp[]
  instructors     Instructor[]
  membershipPlans MembershipPlan[]
  reviews         Review[]
  members         SchoolMember[]
  claims          SchoolClaim[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("schools")
}

// ─────────────────────────────────────────────────────────────────────────────
// INSTRUCTOR
// Public-facing instructor profile — separate from User (internal login)
// An instructor can exist without a Martial account (important for imported schools)
// ─────────────────────────────────────────────────────────────────────────────

model Instructor {
  id          String   @id @default(cuid())
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  // Optional link to a User account
  userId      String?  @unique

  name        String
  role        String   // "Head Instructor", "Instructor", "Assistant", "Kids Coach"
  belt        String?  // Free text: "Black Belt", "Brown Belt", "4th Dan" — flexible for all martial arts
  bio         String?
  photoUrl    String?
  instagram   String?
  isHead      Boolean  @default(false)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)

  classes     Class[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("instructors")
}

// ─────────────────────────────────────────────────────────────────────────────
// MEMBERSHIP PLAN
// The catalogue of plans a school offers publicly (e.g. on their profile page)
// Different from Membership — which is a student's active subscription
// ─────────────────────────────────────────────────────────────────────────────

model MembershipPlan {
  id           String   @id @default(cuid())
  schoolId     String
  school       School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  name         String   // "Monthly BJJ", "Unlimited Access", "10-class Pack"
  description  String?
  price        Float
  currency     String   @default("EUR")
  billingCycle String   // "monthly", "quarterly", "annual", "one-off"
  features     String[] // ["Unlimited classes", "Free Gi", "Competition team access"]
  isPopular    Boolean  @default(false)  // Highlights the recommended plan
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)

  // Stripe (Phase 5)
  stripePriceId String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("membership_plans")
}

// ─────────────────────────────────────────────────────────────────────────────
// REVIEW
// Student reviews of schools
// isVerified = true when the user has an active Membership at this school
// ─────────────────────────────────────────────────────────────────────────────

model Review {
  id          String   @id @default(cuid())
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id])

  rating      Int      // 1–5
  title       String?
  text        String?
  isVerified  Boolean  @default(false)  // Auto-set when user has active membership
  isPublished Boolean  @default(true)

  // School reply
  reply       String?
  repliedAt   DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("reviews")
}

// ─────────────────────────────────────────────────────────────────────────────
// CLASS
// ─────────────────────────────────────────────────────────────────────────────

model Class {
  id           String      @id @default(cuid())
  schoolId     String
  school       School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name         String      // e.g. "BJJ Adults", "Kids No-Gi"
  description  String?
  disciplineId String?
  level        String?     // Beginner, Intermediate, Advanced, All levels
  duration     Int?        // minutes
  capacity     Int?
  price        Float?      // Price per class (0 = included in membership)
  currency     String      @default("GBP")
  isTrial      Boolean     @default(false)
  isActive     Boolean     @default(true)

  // Schedule: [{ dayOfWeek: 1, startTime: "18:00" }]
  schedule     Json?

  // Instructor who teaches this class
  instructorId String?
  instructor   Instructor? @relation(fields: [instructorId], references: [id])

  bookings     Booking[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("classes")
}

// ─────────────────────────────────────────────────────────────────────────────
// BOOKING
// ─────────────────────────────────────────────────────────────────────────────

model Booking {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  classId         String
  class           Class         @relation(fields: [classId], references: [id])
  scheduledAt     DateTime
  status          BookingStatus @default(PENDING)
  paymentMethod   PaymentMethod @default(STRIPE)
  amountPaid      Float?
  currency        String        @default("GBP")
  stripePaymentId String?
  notes           String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("bookings")
}

// ─────────────────────────────────────────────────────────────────────────────
// MEMBERSHIP
// A student's active subscription at a school
// ─────────────────────────────────────────────────────────────────────────────

model Membership {
  id            String           @id @default(cuid())
  userId        String
  user          User             @relation(fields: [userId], references: [id])
  schoolId      String
  school        School           @relation(fields: [schoolId], references: [id])
  planName      String           // e.g. "Monthly BJJ", "Unlimited"
  price         Float
  currency      String           @default("GBP")
  paymentMethod PaymentMethod    @default(STRIPE)
  status        MembershipStatus @default(ACTIVE)
  startDate     DateTime
  endDate       DateTime?
  stripeSubId   String?
  notes         String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("memberships")
}

// ─────────────────────────────────────────────────────────────────────────────
// CAMP (Martial Camps)
// ─────────────────────────────────────────────────────────────────────────────

model Camp {
  id          String   @id @default(cuid())
  schoolId    String?
  school      School?  @relation(fields: [schoolId], references: [id])
  name        String
  description String?
  location    String?
  country     String?
  startDate   DateTime
  endDate     DateTime
  capacity    Int?
  price       Float
  currency    String   @default("GBP")
  coverUrl    String?
  isPublished Boolean  @default(false)

  // Instructors as JSON: [{ name: "Roger Gracie", role: "Head Instructor" }]
  instructors Json?

  bookings    CampBooking[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("camps")
}

model CampBooking {
  id              String        @id @default(cuid())
  campId          String
  camp            Camp          @relation(fields: [campId], references: [id])
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  status          BookingStatus @default(PENDING)
  amountPaid      Float?
  currency        String        @default("GBP")
  stripePaymentId String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("camp_bookings")
}

// ─────────────────────────────────────────────────────────────────────────────
// SCHOOL MEMBER
// Relationship between a user and a school with explicit role + status
// Replaces the simple User.schoolId for multi-school and student tracking
// ─────────────────────────────────────────────────────────────────────────────

model SchoolMember {
  id        String             @id @default(cuid())
  schoolId  String
  school    School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  userId    String
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  role      SchoolMemberRole   @default(STUDENT)
  status    SchoolMemberStatus @default(PENDING)
  joinedAt  DateTime?
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, userId])
  @@map("school_members")
}

// ─────────────────────────────────────────────────────────────────────────────
// SCHOOL CLAIM
// Ownership verification audit trail
// When a school is imported (UNVERIFIED), owners can submit a claim
// ─────────────────────────────────────────────────────────────────────────────

model SchoolClaim {
  id         String      @id @default(cuid())
  schoolId   String
  school     School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  userId     String
  user       User        @relation(fields: [userId], references: [id])

  status     ClaimStatus @default(PENDING)
  evidence   String?     // URL or description of proof (website, email, document)
  notes      String?     // Internal Martial notes
  reviewedBy String?     // Superadmin user ID who reviewed
  reviewedAt DateTime?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("school_claims")
}

// ─────────────────────────────────────────────────────────────────────────────
// PARTNER (Roger Gracie, Buchecha, etc.)
// ─────────────────────────────────────────────────────────────────────────────

model Partner {
  id          String   @id @default(cuid())
  name        String   // "Roger Gracie", "Marcus Almeida Buchecha"
  slug        String   @unique
  title       String?  // "10x World Champion", "13x World Champion"
  bio         String?
  photoUrl    String?
  instagram   String?
  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("partners")
}
