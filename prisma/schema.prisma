generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

generator clientWeb {
  provider = "prisma-client"
  output   = "../apps/web/lib/prisma-client"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum Role {
  SUPERADMIN
  SCHOOL_OWNER
  INSTRUCTOR
  STUDENT
}

enum SchoolStatus {
  UNVERIFIED   // Imported/seeded, not yet confirmed by owner
  CLAIMED      // Owner signed up and confirmed listing
  VERIFIED     // Stripe connected, fully operational
  PARTNER      // Affiliated (Roger Gracie, Checkmat, etc.) — premium listing
  SUSPENDED
}

enum SchoolSource {
  VONSEL          // Imported via Vonsel CSV
  MANUAL          // Added by Superadmin
  SELF_REGISTERED // Academy registered themselves
  AFFILIATE       // Added via affiliation import (e.g. Roger Gracie Association)
}

enum PaymentMethod {
  STRIPE
  CASH
  BANK_TRANSFER
  DIRECT_DEBIT
  OTHER
}

enum SchoolMemberRole {
  OWNER
  ADMIN
  MANAGER
  INSTRUCTOR
  ASSISTANT_INSTRUCTOR
  RECEPTIONIST
  STUDENT
}

enum LeadStage {
  NEW
  CONTACTED
  INTERESTED
  DEMO
  INVITE_SENT
  ONBOARDING
  WON
  LOST
  REJECTED
}

enum SchoolRelationshipType {
  HQ_BRANCH
  FRANCHISE
  AFFILIATE_SCHOOL
  PARTNER
  NETWORK_MEMBER
}

enum SchoolMemberStatus {
  ACTIVE
  INACTIVE
  PENDING     // Invite sent, not yet accepted
  LEAD        // Accepted invite, no membership yet
  FROZEN      // Paused by student (injury, holiday)
  ARCHIVED
}

enum ClaimStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED   // Class happened; see attendedAt for check-in timestamp
  NO_SHOW
}

enum MembershipStatus {
  ACTIVE
  PAUSED
  CANCELLED
  EXPIRED
}

enum LeadStatus {
  NEW
  CONTACTED
  TRIAL_BOOKED
  CONVERTED   // Became a SchoolMember
  LOST
}

enum LeadSource {
  WEBSITE
  INSTAGRAM
  FACEBOOK
  WALK_IN
  REFERRAL
  PHONE
  OTHER
}

enum EventType {
  SEMINAR
  COMPETITION
  OPEN_MAT
  WORKSHOP
  SOCIAL
  CAMP
  OTHER
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum TransactionCategory {
  MEMBERSHIP
  CLASS_BOOKING
  PRODUCT_SALE
  SALARY
  RENT
  EQUIPMENT
  MARKETING
  OTHER
}

// ─────────────────────────────────────────────────────────────────────────────
// AFFILIATION
// Martial arts organizations / associations that affiliate academies
// First use case: Roger Gracie Association (~50 academies worldwide)
// Can have a content platform (e.g. Roger Gracie TV)
// ─────────────────────────────────────────────────────────────────────────────

model Affiliation {
  id          String  @id @default(cuid())
  name        String  // "Roger Gracie Association"
  slug        String  @unique // "roger-gracie"
  description String?
  logoUrl     String?
  website     String?
  instagram   String?
  country     String? // HQ country

  // Optional link to content platform (e.g. Roger Gracie TV)
  // Resolved via ContentPlatform.affiliationId — no FK here to avoid circular
  // Access: affiliation.contentPlatforms

  schools         School[]
  contentPlatforms ContentPlatform[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("affiliations")
}

// ─────────────────────────────────────────────────────────────────────────────
// CONTENT PLATFORM  (Roger Gracie TV, future: Checkmat TV, etc.)
// ─────────────────────────────────────────────────────────────────────────────

model ContentPlatform {
  id            String      @id @default(cuid())
  affiliationId String
  affiliation   Affiliation @relation(fields: [affiliationId], references: [id], onDelete: Cascade)

  name        String  // "Roger Gracie TV"
  slug        String  @unique // "rg-tv"
  description String?
  logoUrl     String?
  bannerUrl   String?
  isActive    Boolean @default(true)

  series       ContentSeries[]
  accesses     ContentAccess[]
  membershipPlans MembershipPlan[] // Plans that include access to this platform

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("content_platforms")
}

// ─────────────────────────────────────────────────────────────────────────────
// CONTENT SERIES  (e.g. "BJJ Fundamentals", "Guard Passing Masterclass")
// ─────────────────────────────────────────────────────────────────────────────

model ContentSeries {
  id          String          @id @default(cuid())
  platformId  String
  platform    ContentPlatform @relation(fields: [platformId], references: [id], onDelete: Cascade)

  title        String
  description  String?
  level        String?  // "Beginner", "Intermediate", "Advanced", "All levels"
  thumbnailUrl String?
  sortOrder    Int     @default(0)
  isPublished  Boolean @default(false)

  videos      ContentVideo[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("content_series")
}

// ─────────────────────────────────────────────────────────────────────────────
// CONTENT VIDEO  (individual lesson/video within a series)
// ─────────────────────────────────────────────────────────────────────────────

model ContentVideo {
  id        String        @id @default(cuid())
  seriesId  String
  series    ContentSeries @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  title        String
  description  String?
  durationMin  Int?     // minutes
  videoUrl     String?  // Vimeo / YouTube / S3 signed URL
  thumbnailUrl String?
  sortOrder    Int     @default(0)
  isPublished  Boolean @default(false)
  isFreePreview Boolean @default(false) // Visible without subscription

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("content_videos")
}

// ─────────────────────────────────────────────────────────────────────────────
// CONTENT ACCESS
// Granted when a user activates a Membership that includes a ContentPlatform
// ─────────────────────────────────────────────────────────────────────────────

model ContentAccess {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  platformId  String
  platform    ContentPlatform @relation(fields: [platformId], references: [id], onDelete: Cascade)
  membershipId String          @unique
  membership  Membership      @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  startDate   DateTime
  endDate     DateTime?  // null = active while membership is active
  isActive    Boolean    @default(true)
  revokedAt   DateTime?  // set when membership expires or is cancelled

  @@unique([userId, platformId]) // one active access per platform per user
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("content_accesses")
}

// ─────────────────────────────────────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String?
  phone          String?
  dateOfBirth    DateTime?
  avatarUrl      String?
  supabaseAuthId String?  @unique @db.Uuid
  role           Role     @default(STUDENT)

  // School this user manages (if SCHOOL_OWNER or INSTRUCTOR)
  schoolId       String?
  school         School?  @relation("SchoolStaff", fields: [schoolId], references: [id])

  // Schools this user claimed ownership of
  claimedSchools School[] @relation("SchoolClaimer")

  // Relations
  bookings         Booking[]
  memberships      Membership[]
  contentAccesses  ContentAccess[]
  campBookings     CampBooking[]
  reviews          Review[]
  schoolMembers    SchoolMember[]
  schoolClaims     SchoolClaim[]
  gradings         Grading[]       @relation("GradingStudent")
  gradingsGiven    Grading[]       @relation("GradingPromoter")
  leads            Lead[]          @relation("LeadConvertedUser")
  leadNotes        LeadNote[]
  transactions     Transaction[]   @relation("TransactionUser")
  userWaivers      UserWaiver[]
  sentInvitations  SchoolInvitation[] @relation("InvitedByUser")
  preference       UserPreference?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("users")
}

// ─────────────────────────────────────────────────────────────────────────────
// DISCIPLINE
// ─────────────────────────────────────────────────────────────────────────────

model Discipline {
  id      String             @id @default(cuid())
  name    String             @unique // "BJJ", "MMA", "Muay Thai", etc.
  slug    String             @unique
  schools SchoolDiscipline[]
  classes Class[]

  @@map("disciplines")
}

model SchoolDiscipline {
  schoolId     String
  disciplineId String
  school       School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  discipline   Discipline @relation(fields: [disciplineId], references: [id])

  @@id([schoolId, disciplineId])
  @@map("school_disciplines")
}

// ─────────────────────────────────────────────────────────────────────────────
// SCHOOL
// ─────────────────────────────────────────────────────────────────────────────

model School {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  status      SchoolStatus @default(UNVERIFIED)
  source      SchoolSource @default(SELF_REGISTERED)

  // Affiliation (Roger Gracie, Checkmat, Alliance, etc.)
  affiliationId   String?
  affiliation     Affiliation? @relation(fields: [affiliationId], references: [id])

  // Location
  country     String?
  city        String?
  address     String?
  postcode    String?
  lat         Float?
  lng         Float?

  // Contact
  phone       String?
  email       String?
  website     String?
  language    String   @default("en") // en | es | pt | fr

  // Social
  instagram   String?
  facebook    String?
  youtube     String?
  tiktok      String?

  // Profile
  description     String?
  tagline         String?  // "Elite BJJ training in the heart of Málaga"
  logoUrl         String?
  coverUrl        String?
  photos          String[] // Array of image URLs

  // Public listing
  priceFrom       Float?
  hasFreeTrialCls Boolean  @default(false)
  facilities      String[]
  foundedYear     Int?
  totalStudents   Int?

  // Google
  googleRating    Float?
  googleReviews   Int?
  googlePlaceId   String?

  // V1 migration reference
  v1UserId        Int?     @unique // V1 user_id (e.g. 798 for Roger Gracie Málaga)

  // Booking defaults — inherited by all classes unless overridden per-class
  defaultBookingSettings Json @default("{}")

  // Stripe
  stripeAccountId String?

  // Hierarchy (HQ / branch / franchise)
  parentId                 String?
  parent                   School?               @relation("SchoolHierarchy", fields: [parentId], references: [id])
  branches                 School[]              @relation("SchoolHierarchy")
  parentRelationshipType   SchoolRelationshipType?

  // CRM pipeline (separate from platform status)
  leadStage   LeadStage?

  // Ownership
  claimedBy    User?     @relation("SchoolClaimer", fields: [claimedById], references: [id])
  claimedById  String?
  claimedAt    DateTime?

  // Relations
  staff           User[]             @relation("SchoolStaff")
  disciplines     SchoolDiscipline[]
  classes         Class[]
  events          Event[]
  memberships     Membership[]
  camps           Camp[]
  instructors     Instructor[]
  membershipPlans MembershipPlan[]
  reviews         Review[]
  members         SchoolMember[]
  claims          SchoolClaim[]
  gradings        Grading[]
  leads           Lead[]
  waivers         Waiver[]
  transactions    Transaction[]
  invitations     SchoolInvitation[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("schools")
}

// ─────────────────────────────────────────────────────────────────────────────
// INSTRUCTOR
// Public-facing profile — can exist without a Martial user account
// ─────────────────────────────────────────────────────────────────────────────

model Instructor {
  id          String   @id @default(cuid())
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  userId      String?  @unique // Optional link to User account

  name        String
  role        String   // "Head Instructor", "Instructor", "Kids Coach"
  belt        String?  // "Black Belt 4th Degree" — free text, works for all arts
  bio         String?
  photoUrl    String?
  instagram   String?
  isHead      Boolean  @default(false)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)

  classes     Class[]
  events      Event[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("instructors")
}

// ─────────────────────────────────────────────────────────────────────────────
// MEMBERSHIP PLAN
// Catalogue of plans a school offers publicly
// ─────────────────────────────────────────────────────────────────────────────

model MembershipPlan {
  id           String   @id @default(cuid())
  schoolId     String
  school       School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  name         String
  description  String?
  price        Float
  currency     String   @default("EUR")
  billingCycle String   // "monthly" | "quarterly" | "annual" | "one-off"
  features     String[]
  isPopular    Boolean  @default(false)
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)

  // Class-limited plans (e.g. "Bono 8 clases")
  // null = unlimited classes included
  classLimit   Int?

  // Content platform access (e.g. Roger Gracie TV)
  contentPlatformId String?
  contentPlatform   ContentPlatform? @relation(fields: [contentPlatformId], references: [id])

  // Stripe (Phase 5)
  stripePriceId String?

  memberships  Membership[] // Memberships created from this plan

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("membership_plans")
}

// ─────────────────────────────────────────────────────────────────────────────
// REVIEW
// ─────────────────────────────────────────────────────────────────────────────

model Review {
  id          String   @id @default(cuid())
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id])

  rating      Int      // 1–5
  title       String?
  text        String?
  isVerified  Boolean  @default(false) // true when user has active membership
  isPublished Boolean  @default(true)

  reply       String?
  repliedAt   DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("reviews")
}

// ─────────────────────────────────────────────────────────────────────────────
// CLASS
// Recurring class definition. Schedule stored as JSON array.
// ─────────────────────────────────────────────────────────────────────────────

model Class {
  id           String     @id @default(cuid())
  schoolId     String
  school       School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  name         String
  description  String?
  disciplineId String?
  discipline   Discipline? @relation(fields: [disciplineId], references: [id])
  level        String?    // "Beginner" | "Intermediate" | "Advanced" | "All levels"
  duration     Int?       // minutes
  capacity     Int?
  price        Float?     // 0 = included in membership
  currency     String     @default("EUR")
  isTrial        Boolean  @default(false)
  isActive       Boolean  @default(true)
  isPublished    Boolean  @default(false) // visible on Explore
  paymentMethods String[] @default([])    // ["STRIPE","CASH","BANK_TRANSFER"]

  // Booking settings — null = inherit school defaultBookingSettings
  bookingSettings Json?

  // Weekly schedule: [{ dayOfWeek: 1, startTime: "18:00", endTime: "19:30" }]
  schedule     Json?

  instructorId String?
  instructor   Instructor? @relation(fields: [instructorId], references: [id])

  bookings     Booking[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("classes")
}

// ─────────────────────────────────────────────────────────────────────────────
// EVENT
// One-off events: seminars, competitions, open mats, social events
// ─────────────────────────────────────────────────────────────────────────────

model Event {
  id          String    @id @default(cuid())
  schoolId    String
  school      School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  title       String
  description String?
  type        EventType @default(OTHER)
  location    String?
  startAt     DateTime
  endAt       DateTime?
  capacity    Int?
  coverUrl    String?
  isPublished    Boolean  @default(false)
  isCancelled    Boolean  @default(false)
  externalUrl    String?
  paymentMethods String[] @default([]) // ["STRIPE","CASH","BANK_TRANSFER"]

  instructorId String?
  instructor   Instructor?   @relation(fields: [instructorId], references: [id])
  tickets      EventTicket[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("events")
}

model EventTicket {
  id            String  @id @default(cuid())
  eventId       String
  event         Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)

  name          String           // e.g. "Early Bird", "Member", "VIP"
  description   String?
  price         Float   @default(0)
  currency      String  @default("EUR")
  capacity      Int?              // null = unlimited
  sortOrder     Int     @default(0)
  stripePriceId String?           // wired when Stripe is connected

  createdAt     DateTime @default(now())

  @@map("event_tickets")
}

// ─────────────────────────────────────────────────────────────────────────────
// BOOKING
// A student's reservation for a specific class occurrence.
// attendedAt = check-in timestamp (null = not yet / no-show)
// membershipId = which active membership covers this booking
// ─────────────────────────────────────────────────────────────────────────────

model Booking {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  classId         String
  class           Class         @relation(fields: [classId], references: [id])

  // Which membership covers this booking (optional: drop-ins can be paid directly)
  membershipId    String?
  membership      Membership?   @relation(fields: [membershipId], references: [id])

  scheduledAt     DateTime
  attendedAt      DateTime?     // null = pending / no-show; set = checked in
  status          BookingStatus @default(PENDING)
  paymentMethod   PaymentMethod @default(STRIPE)
  amountPaid      Float?
  currency        String        @default("EUR")
  stripePaymentId String?
  notes           String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("bookings")
}

// ─────────────────────────────────────────────────────────────────────────────
// MEMBERSHIP
// A student's active subscription at a school.
// classesUsed tracks consumption for class-limited plans.
// ─────────────────────────────────────────────────────────────────────────────

model Membership {
  id            String           @id @default(cuid())
  userId        String
  user          User             @relation(fields: [userId], references: [id])
  schoolId      String
  school        School           @relation(fields: [schoolId], references: [id])

  // Link to the plan that originated this membership (optional for legacy/manual)
  planId        String?
  plan          MembershipPlan?  @relation(fields: [planId], references: [id])

  planName      String           // Denormalised name for display / history
  price         Float
  currency      String           @default("EUR")
  paymentMethod PaymentMethod    @default(STRIPE)
  status        MembershipStatus @default(ACTIVE)
  startDate     DateTime
  endDate       DateTime?

  // For class-limited plans (bono 8 clases, etc.)
  classesUsed   Int              @default(0)

  stripeSubId   String?
  notes         String?

  // Content platform access granted by this membership
  contentAccess ContentAccess?

  bookings      Booking[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("memberships")
}

// ─────────────────────────────────────────────────────────────────────────────
// CAMP  (Martial Camps — multi-day training camps)
// ─────────────────────────────────────────────────────────────────────────────

model Camp {
  id          String   @id @default(cuid())
  schoolId    String?
  school      School?  @relation(fields: [schoolId], references: [id])

  name        String
  description String?
  location    String?
  country     String?
  startDate   DateTime
  endDate     DateTime
  capacity    Int?
  price       Float
  currency    String   @default("EUR")
  coverUrl    String?
  isPublished Boolean  @default(false)

  // Instructors as JSON (may include external guests)
  instructors Json?

  bookings    CampBooking[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("camps")
}

model CampBooking {
  id              String        @id @default(cuid())
  campId          String
  camp            Camp          @relation(fields: [campId], references: [id])
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  status          BookingStatus @default(PENDING)
  amountPaid      Float?
  currency        String        @default("EUR")
  stripePaymentId String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("camp_bookings")
}

// ─────────────────────────────────────────────────────────────────────────────
// SCHOOL MEMBER
// Student/instructor relationship with a school.
// Tracks belt rank, emergency contact, medical info.
// ─────────────────────────────────────────────────────────────────────────────

model SchoolMember {
  id        String             @id @default(cuid())
  schoolId  String
  school    School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  userId    String
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  role      SchoolMemberRole   @default(STUDENT)
  status    SchoolMemberStatus @default(PENDING)
  joinedAt  DateTime?

  // Belt / rank (current)
  belt      String?    // "White Belt", "Blue Belt", "Purple Belt"
  beltDegree Int?      // stripes/degrees: 0–4
  beltDate  DateTime?  // date current belt was awarded

  // Emergency & medical
  emergencyContact String?  // "María García — +34 666 123 456"
  medicalNotes     String?  // "Right knee injury, penicillin allergy"

  notes     String?   // Internal school notes

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, userId])
  @@map("school_members")
}

// ─────────────────────────────────────────────────────────────────────────────
// SCHOOL CLAIM
// ─────────────────────────────────────────────────────────────────────────────

model SchoolClaim {
  id         String      @id @default(cuid())
  schoolId   String
  school     School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  userId     String
  user       User        @relation(fields: [userId], references: [id])

  status     ClaimStatus @default(PENDING)
  evidence   String?
  notes      String?
  reviewedBy String?
  reviewedAt DateTime?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("school_claims")
}

// ─────────────────────────────────────────────────────────────────────────────
// GRADING
// Belt promotion records. Maps V1 promote_students + studnet_grading_notes.
// ─────────────────────────────────────────────────────────────────────────────

model Grading {
  id           String   @id @default(cuid())
  schoolId     String
  school       School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  userId       String
  user         User     @relation("GradingStudent", fields: [userId], references: [id])

  promotedById String?
  promotedBy   User?    @relation("GradingPromoter", fields: [promotedById], references: [id])

  fromBelt     String?  // "White Belt"
  toBelt       String   // "Blue Belt"
  toDegree     Int?     // 0 = plain belt, 1–4 = stripes/degrees
  gradedAt     DateTime
  notes        String?
  isPublic     Boolean  @default(true) // show on student profile

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("gradings")
}

// ─────────────────────────────────────────────────────────────────────────────
// LEAD + LEAD NOTE
// Prospective students. Maps V1 leads (865 rows) + lead_notes (36 rows).
// ─────────────────────────────────────────────────────────────────────────────

model Lead {
  id       String     @id @default(cuid())
  schoolId String
  school   School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  name         String
  email        String?
  phone        String?
  source       LeadSource @default(OTHER)
  status       LeadStatus @default(NEW)
  message      String?    // Initial enquiry message
  interestedIn String?    // "BJJ Adults", "Kids Class", "Private Lessons"

  // If they converted to a member
  convertedUserId String?
  convertedUser   User?    @relation("LeadConvertedUser", fields: [convertedUserId], references: [id])
  convertedAt     DateTime?

  notes       LeadNote[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("leads")
}

model LeadNote {
  id       String @id @default(cuid())
  leadId   String
  lead     Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  text      String
  createdAt DateTime @default(now())

  @@map("lead_notes")
}

// ─────────────────────────────────────────────────────────────────────────────
// SCHOOL INVITATION
// Admin-initiated invite to onboard a new school onto the platform.
// ─────────────────────────────────────────────────────────────────────────────

enum InvitationStatus {
  PENDING     // Created, email not yet sent
  SENT        // Invite email sent
  OPENED      // Link clicked
  REGISTERED  // School completed onboarding → School record created
  DECLINED    // School declined or unsubscribed
}

enum InvitationSource {
  MANUAL  // Admin typed name + email
  IMPORT  // Bulk CSV/Excel import
}

model SchoolInvitation {
  id    String @id @default(cuid())
  token String @unique @default(cuid())

  // Basic info (filled by admin or from import)
  name       String
  email      String
  phone      String?
  city       String?
  country    String?
  activities String?  // "BJJ, Grappling, MMA"
  website    String?
  notes      String?

  status InvitationStatus @default(PENDING)
  source InvitationSource @default(MANUAL)

  // Admin who created the invite
  invitedById String?
  invitedBy   User?   @relation("InvitedByUser", fields: [invitedById], references: [id])

  // School created after successful onboarding
  // Not unique — allows re-inviting after decline/expiry
  schoolId String?
  school   School? @relation(fields: [schoolId], references: [id])

  // Only one invitation per school should be active at a time
  isActive Boolean @default(true)

  sentAt       DateTime?
  openedAt     DateTime?
  registeredAt DateTime?

  @@index([schoolId, isActive])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("school_invitations")
}

// ─────────────────────────────────────────────────────────────────────────────
// WAIVER + USER WAIVER
// Legal agreements. Maps V1 user_waivers (48 rows).
// ─────────────────────────────────────────────────────────────────────────────

model Waiver {
  id        String  @id @default(cuid())
  schoolId  String
  school    School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  title     String   // "Liability Waiver & Informed Consent"
  content   String   // HTML or Markdown legal text
  version   String   @default("1.0")
  isActive  Boolean  @default(true)

  signedBy  UserWaiver[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("waivers")
}

model UserWaiver {
  id        String  @id @default(cuid())
  waiverId  String
  waiver    Waiver  @relation(fields: [waiverId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id])

  signedAt  DateTime @default(now())
  ipAddress String?
  signature String?  // base64 or typed name

  @@unique([waiverId, userId])
  @@map("user_waivers")
}

// ─────────────────────────────────────────────────────────────────────────────
// TRANSACTION
// School financial records: income + expenses in one table.
// Maps V1 expenses (119) + incomes (6) + orders (43).
// ─────────────────────────────────────────────────────────────────────────────

model Transaction {
  id          String              @id @default(cuid())
  schoolId    String
  school      School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  type        TransactionType
  category    TransactionCategory @default(OTHER)
  amount      Float
  currency    String              @default("EUR")
  description String?
  date        DateTime

  // Optional links to source record
  membershipId String?
  bookingId    String?
  userId       String?
  user         User?   @relation("TransactionUser", fields: [userId], references: [id])

  // Stripe (Phase 5)
  stripePaymentIntentId String?

  notes       String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("transactions")
}

// ─────────────────────────────────────────────────────────────────────────────
// USER PREFERENCE
// Stores last selected context for school picker. Not an authorization source.
// Authorization always comes from SchoolMember.
// ─────────────────────────────────────────────────────────────────────────────

model UserPreference {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Last active school context — suggestion only, not authorization
  lastSchoolId        String?
  lastContextType     String?  // "SCHOOL" | "PERSONAL" | "ADMIN"

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("user_preferences")
}

// ─────────────────────────────────────────────────────────────────────────────
// STORE  (Phase future — schema defined, not connected yet)
// Maps V1 products (15) + orders (43)
// ─────────────────────────────────────────────────────────────────────────────

model ProductCategory {
  id        String    @id @default(cuid())
  schoolId  String
  name      String
  slug      String

  products  Product[]

  @@unique([schoolId, slug])
  @@map("product_categories")
}

model Product {
  id          String          @id @default(cuid())
  schoolId    String
  categoryId  String?
  category    ProductCategory? @relation(fields: [categoryId], references: [id])

  name        String
  description String?
  price       Float
  currency    String   @default("EUR")
  stock       Int?     // null = unlimited (e.g. digital products)
  imageUrl    String?
  isActive    Boolean  @default(true)

  orderItems  OrderItem[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("products")
}

model Order {
  id        String  @id @default(cuid())
  schoolId  String
  userId    String

  status    String  @default("PENDING") // PENDING | PAID | CANCELLED | REFUNDED
  total     Float
  currency  String  @default("EUR")

  stripePaymentIntentId String?

  items     OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("orders")
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String
  order      Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId  String
  product    Product @relation(fields: [productId], references: [id])

  quantity   Int
  unitPrice  Float
  currency   String @default("EUR")

  @@map("order_items")
}

// ─────────────────────────────────────────────────────────────────────────────
// PARTNER  (Brand ambassadors: Roger Gracie the person, Buchecha, etc.)
// Different from Affiliation (the organization)
// ─────────────────────────────────────────────────────────────────────────────

model Partner {
  id          String   @id @default(cuid())
  name        String   // "Roger Gracie", "Marcus Almeida Buchecha"
  slug        String   @unique
  title       String?  // "10x World Champion"
  bio         String?
  photoUrl    String?
  instagram   String?
  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("partners")
}
