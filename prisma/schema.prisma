generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

generator clientWeb {
  provider = "prisma-client"
  output   = "../apps/web/lib/prisma-client"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum Role {
  SUPERADMIN
  SCHOOL_OWNER
  INSTRUCTOR
  STUDENT
}

enum SchoolStatus {
  UNVERIFIED // Imported/seeded, not yet confirmed by owner
  CLAIMED // Owner signed up and confirmed listing
  VERIFIED // Stripe connected, fully operational
  PARTNER // Affiliated (Roger Gracie, Checkmat, etc.) — premium listing
  SUSPENDED
  ARCHIVED // Soft-deleted by admin — hidden from public listings, data kept
}

enum SchoolType {
  SCHOOL // Regular martial arts academy
  CAMP // Temporary event — elite instructor + iconic location
  BUSINESS // Gym, studio, or marketplace business (future)
}

enum SchoolSource {
  VONSEL // Imported via Vonsel CSV
  MANUAL // Added by Superadmin
  SELF_REGISTERED // Academy registered themselves
  AFFILIATE // Added via affiliation import (e.g. Roger Gracie Association)
}

enum PaymentMethod {
  STRIPE
  REVOLUT
  CASH
  BANK_TRANSFER
  DIRECT_DEBIT
  OTHER
}

enum SchoolMemberRole {
  OWNER
  ADMIN
  MANAGER
  INSTRUCTOR
  ASSISTANT_INSTRUCTOR
  RECEPTIONIST
  STUDENT
}

enum LeadStage {
  NEW
  CONTACTED
  INTERESTED
  DEMO
  INVITE_SENT
  ONBOARDING
  WON
  LOST
  REJECTED
}

enum SchoolRelationshipType {
  HQ_BRANCH
  FRANCHISE
  AFFILIATE_SCHOOL
  PARTNER
  NETWORK_MEMBER
}

enum SchoolMemberStatus {
  ACTIVE
  INACTIVE
  PENDING // Invite sent, not yet accepted
  LEAD // Accepted invite, no membership yet
  FROZEN // Paused by student (injury, holiday)
  ARCHIVED
}

enum ClaimStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED // Class happened; see attendedAt for check-in timestamp
  NO_SHOW
}

enum MembershipStatus {
  PENDING
  ACTIVE
  PAUSED
  CANCELLED
  EXPIRED
}

enum LeadStatus {
  NEW
  CONTACTED
  TRIAL_BOOKED
  CONVERTED // Became a SchoolMember
  LOST
}

enum LeadSource {
  WEBSITE
  INSTAGRAM
  FACEBOOK
  WALK_IN
  REFERRAL
  PHONE
  OTHER
}

enum EventType {
  SEMINAR
  COMPETITION
  OPEN_MAT
  WORKSHOP
  SOCIAL
  CAMP
  OTHER
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum TransactionCategory {
  MEMBERSHIP
  CLASS_BOOKING
  PRODUCT_SALE
  SALARY
  RENT
  EQUIPMENT
  MARKETING
  OTHER
}

enum TransactionStatus {
  PAID
  PENDING
  FAILED
  REFUNDED
  CANCELLED
}

// Martial's own SaaS subscription status for a school (schools paying
// Martial), mirrors Stripe's real Subscription.status values so webhook
// handlers can map 1:1 without inventing intermediate states.
enum SchoolSubscriptionStatus {
  TRIALING
  ACTIVE
  INCOMPLETE
  INCOMPLETE_EXPIRED
  PAST_DUE
  UNPAID
  PAUSED
  CANCELED
  INACTIVE
}

enum StripeWebhookEventStatus {
  PROCESSING
  PROCESSED
  FAILED
}

// ─────────────────────────────────────────────────────────────────────────────
// AFFILIATION
// Martial arts organizations / associations that affiliate academies
// First use case: Roger Gracie Association (~50 academies worldwide)
// Can have a content platform (e.g. Roger Gracie TV)
// ─────────────────────────────────────────────────────────────────────────────

model Affiliation {
  id          String  @id @default(cuid())
  name        String // "Roger Gracie Association"
  slug        String  @unique // "roger-gracie"
  description String?
  logoUrl     String?
  website     String?
  instagram   String?
  country     String? // HQ country

  // Optional link to content platform (e.g. Roger Gracie TV)
  // Resolved via ContentPlatform.affiliationId — no FK here to avoid circular
  // Access: affiliation.contentPlatforms

  schools          School[]
  contentPlatforms ContentPlatform[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("affiliations")
}

// ─────────────────────────────────────────────────────────────────────────────
// CONTENT PLATFORM  (Roger Gracie TV, future: Checkmat TV, etc.)
// ─────────────────────────────────────────────────────────────────────────────

model ContentPlatform {
  id            String      @id @default(cuid())
  affiliationId String
  affiliation   Affiliation @relation(fields: [affiliationId], references: [id], onDelete: Cascade)

  name        String // "Roger Gracie TV"
  slug        String  @unique // "rg-tv"
  description String?
  logoUrl     String?
  bannerUrl   String?
  isActive    Boolean @default(true)

  series          ContentSeries[]
  accesses        ContentAccess[]
  membershipPlans MembershipPlan[] // Plans that include access to this platform

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("content_platforms")
}

// ─────────────────────────────────────────────────────────────────────────────
// CONTENT SERIES  (e.g. "BJJ Fundamentals", "Guard Passing Masterclass")
// ─────────────────────────────────────────────────────────────────────────────

model ContentSeries {
  id         String          @id @default(cuid())
  platformId String
  platform   ContentPlatform @relation(fields: [platformId], references: [id], onDelete: Cascade)

  title        String
  description  String?
  level        String? // "Beginner", "Intermediate", "Advanced", "All levels"
  thumbnailUrl String?
  sortOrder    Int     @default(0)
  isPublished  Boolean @default(false)

  videos ContentVideo[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("content_series")
}

// ─────────────────────────────────────────────────────────────────────────────
// CONTENT VIDEO  (individual lesson/video within a series)
// ─────────────────────────────────────────────────────────────────────────────

model ContentVideo {
  id       String        @id @default(cuid())
  seriesId String
  series   ContentSeries @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  title         String
  description   String?
  durationMin   Int? // minutes
  videoUrl      String? // Vimeo / YouTube / S3 signed URL
  thumbnailUrl  String?
  sortOrder     Int     @default(0)
  isPublished   Boolean @default(false)
  isFreePreview Boolean @default(false) // Visible without subscription

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("content_videos")
}

// ─────────────────────────────────────────────────────────────────────────────
// CONTENT ACCESS
// Granted when a user activates a Membership that includes a ContentPlatform
// ─────────────────────────────────────────────────────────────────────────────

model ContentAccess {
  id           String          @id @default(cuid())
  userId       String
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  platformId   String
  platform     ContentPlatform @relation(fields: [platformId], references: [id], onDelete: Cascade)
  membershipId String          @unique
  membership   Membership      @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  startDate DateTime
  endDate   DateTime? // null = active while membership is active
  isActive  Boolean   @default(true)
  revokedAt DateTime? // set when membership expires or is cancelled
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([userId, platformId]) // one active access per platform per user
  @@map("content_accesses")
}

// ─────────────────────────────────────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String?
  phone          String?
  dateOfBirth    DateTime?
  avatarUrl      String?
  supabaseAuthId String?   @unique @db.Uuid
  role           Role      @default(STUDENT)

  // School this user manages (if SCHOOL_OWNER or INSTRUCTOR)
  schoolId String?
  school   School? @relation("SchoolStaff", fields: [schoolId], references: [id])

  // Schools this user claimed ownership of
  claimedSchools School[] @relation("SchoolClaimer")

  // Relations
  bookings               Booking[]
  eventBookings          EventBooking[]
  memberships            Membership[]
  contentAccesses        ContentAccess[]
  campBookings           CampBooking[]
  reviews                Review[]
  schoolMembers          SchoolMember[]
  schoolClaims           SchoolClaim[]
  gradings               Grading[]          @relation("GradingStudent")
  gradingsGiven          Grading[]          @relation("GradingPromoter")
  leads                  Lead[]             @relation("LeadConvertedUser")
  leadNotes              LeadNote[]
  transactions           Transaction[]      @relation("TransactionUser")
  userWaivers            UserWaiver[]
  sentInvitations        SchoolInvitation[] @relation("InvitedByUser")
  preference             UserPreference?
  loginHistory           LoginHistory[]
  impersonationsAsActor  ImpersonationLog[] @relation("ImpersonationActor")
  impersonationsAsTarget ImpersonationLog[] @relation("ImpersonationTarget")
  targetedNotifications  Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// ─────────────────────────────────────────────────────────────────────────────
// DISCIPLINE
// ─────────────────────────────────────────────────────────────────────────────

model Discipline {
  id      String             @id @default(cuid())
  name    String             @unique // "BJJ", "MMA", "Muay Thai", etc.
  slug    String             @unique
  schools SchoolDiscipline[]
  classes Class[]

  @@map("disciplines")
}

model SchoolDiscipline {
  schoolId     String
  disciplineId String
  school       School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  discipline   Discipline @relation(fields: [disciplineId], references: [id])

  @@id([schoolId, disciplineId])
  @@map("school_disciplines")
}

// ─────────────────────────────────────────────────────────────────────────────
// FACILITY
// Master catalog for the super admin's platform-wide facility options.
// School.facilities (String[]) remains untouched — this catalog is additive,
// not yet backing that field. See project_admin_panel_scope memory.
// ─────────────────────────────────────────────────────────────────────────────

model Facility {
  id      String           @id @default(cuid())
  name    String           @unique // "Mats area", "Showers", "Parking"
  slug    String           @unique
  icon    String? // optional lucide icon name
  schools SchoolFacility[]

  @@map("facilities")
}

model SchoolFacility {
  schoolId   String
  facilityId String
  school     School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  facility   Facility @relation(fields: [facilityId], references: [id])

  @@id([schoolId, facilityId])
  @@map("school_facilities")
}

// ─────────────────────────────────────────────────────────────────────────────
// SCHOOL
// ─────────────────────────────────────────────────────────────────────────────

model School {
  id     String       @id @default(cuid())
  name   String
  slug   String       @unique
  status SchoolStatus @default(UNVERIFIED)
  source SchoolSource @default(SELF_REGISTERED)
  type   SchoolType   @default(SCHOOL)

  // Affiliation (Roger Gracie, Checkmat, Alliance, etc.)
  affiliationId String?
  affiliation   Affiliation? @relation(fields: [affiliationId], references: [id])

  // Location
  country  String?
  city     String?
  address  String?
  postcode String?
  lat      Float?
  lng      Float?

  // Contact
  phone    String?
  email    String?
  website  String?
  language String  @default("en") // en | es | pt | fr

  // Social
  instagram String?
  facebook  String?
  youtube   String?
  tiktok    String?

  // Profile
  description String?
  tagline     String? // "Elite BJJ training in the heart of Málaga"
  logoUrl     String?
  coverUrl    String?
  coverPosY   Float    @default(50) // vertical focal point %, Facebook-style cover reposition
  photos      String[] // Array of image URLs

  // Public listing
  priceFrom       Float?
  hasFreeTrialCls Boolean  @default(false)
  facilities      String[]
  foundedYear     Int?
  totalStudents   Int?

  // Google
  googleRating  Float?
  googleReviews Int?
  googlePlaceId String?

  // V1 migration reference
  v1UserId Int? @unique // V1 user_id (e.g. 798 for Roger Gracie Málaga)

  // Booking defaults — inherited by all classes unless overridden per-class
  defaultBookingSettings Json @default("{}")

  // Cancellation policy — how access is handled after a student cancels a paid membership
  // IMMEDIATE: access ends the day of cancellation
  // UNTIL_END_OF_PERIOD: student retains access until the membership's endDate (Netflix model)
  cancelPolicy String @default("IMMEDIATE")

  // Optional feature modules the school can enable/disable, e.g. { "store": true, "curriculum": false, "news": true }
  // Missing keys default to disabled — read via a helper that merges against defaults, not raw access.
  modules Json @default("{}")

  // Stripe — each school stores their own keys
  stripePublishableKey String?
  stripeSecretKey      String?
  stripeWebhookSecret  String?

  // Revolut Merchant — each school stores their own keys
  revolutPublicKey     String?
  revolutSecretKey     String?
  revolutWebhookSecret String? // signing_secret returned when we register the webhook

  // Hierarchy (HQ / branch / franchise)
  parentId               String?
  parent                 School?                 @relation("SchoolHierarchy", fields: [parentId], references: [id])
  branches               School[]                @relation("SchoolHierarchy")
  parentRelationshipType SchoolRelationshipType?

  // CRM pipeline (separate from platform status)
  leadStage LeadStage?

  // Ownership
  claimedBy   User?     @relation("SchoolClaimer", fields: [claimedById], references: [id])
  claimedById String?
  claimedAt   DateTime?

  // Relations
  staff             User[]             @relation("SchoolStaff")
  impersonationLogs ImpersonationLog[]
  disciplines       SchoolDiscipline[]
  facilityCatalog   SchoolFacility[]
  classes           Class[]
  events            Event[]
  memberships       Membership[]
  camps             Camp[]
  instructors       Instructor[]
  membershipPlans   MembershipPlan[]
  reviews           Review[]
  members           SchoolMember[]
  claims            SchoolClaim[]
  gradings          Grading[]
  gradingSystems    GradingSystem[]
  leads             Lead[]
  waivers           Waiver[]
  transactions      Transaction[]
  invitations       SchoolInvitation[]
  notifications     Notification[]

  // Martial SaaS billing — school paying the platform (separate from the
  // school's own Stripe keys above, which they use to charge their members)
  subscription SchoolSubscription?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("schools")
}

// ─────────────────────────────────────────────────────────────────────────────
// INSTRUCTOR
// Public-facing profile — can exist without a Martial user account
// ─────────────────────────────────────────────────────────────────────────────

model Instructor {
  id       String  @id @default(cuid())
  schoolId String
  school   School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  userId   String? @unique // Optional link to User account

  name      String
  role      String // "Head Instructor", "Instructor", "Kids Coach"
  belt      String? // "Black Belt 4th Degree" — free text, works for all arts
  bio       String?
  photoUrl  String?
  instagram String?
  isHead    Boolean @default(false)
  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  classes Class[]
  events  Event[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("instructors")
}

// ─────────────────────────────────────────────────────────────────────────────
// MEMBERSHIP PLAN
// Catalogue of plans a school offers publicly
// ─────────────────────────────────────────────────────────────────────────────

model MembershipPlan {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  name         String
  description  String?
  price        Float   @default(0)
  currency     String  @default("EUR")
  planType     String  @default("SUBSCRIPTION") // SUBSCRIPTION | SINGLE_PASS | TRIAL
  billingCycle String  @default("monthly") // monthly | quarterly | annual | one-off
  validityDays Int? // for SINGLE_PASS / TRIAL: days valid after activation
  isPublic     Boolean @default(true)
  isPopular    Boolean @default(false)
  isActive     Boolean @default(true)
  sortOrder    Int     @default(0)

  // Flexible per-class access rules
  // { classRules: [{classId, unlimited, limit?, limitType?}], globalLimit?, globalLimitType? }
  classAccess Json @default("{}")

  // Content platform access (e.g. Roger Gracie TV)
  contentPlatformId String?
  contentPlatform   ContentPlatform? @relation(fields: [contentPlatformId], references: [id])

  // Media
  imageUrl String?

  // Payment methods accepted for this plan (CASH, STRIPE, BANK_TRANSFER, etc.)
  paymentMethods String[] @default([])

  // Stripe (Phase 5)
  stripePriceId String?

  memberships Membership[] // Memberships created from this plan

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("membership_plans")
}

// ─────────────────────────────────────────────────────────────────────────────
// REVIEW
// ─────────────────────────────────────────────────────────────────────────────

model Review {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation(fields: [userId], references: [id])

  rating      Int // 1–5
  title       String?
  text        String?
  isVerified  Boolean @default(false) // true when user has active membership
  isPublished Boolean @default(true)

  reply     String?
  repliedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("reviews")
}

// ─────────────────────────────────────────────────────────────────────────────
// CLASS
// Recurring class definition. Schedule stored as JSON array.
// ─────────────────────────────────────────────────────────────────────────────

model Class {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  name           String
  description    String?
  coverUrl       String? // class banner/image
  disciplineId   String?
  discipline     Discipline? @relation(fields: [disciplineId], references: [id])
  level          String? // "Beginner" | "Intermediate" | "Advanced" | "All levels"
  duration       Int? // minutes
  capacity       Int?
  price          Float? // 0 = included in membership
  currency       String      @default("EUR")
  isTrial        Boolean     @default(false)
  isActive       Boolean     @default(true)
  isPublished    Boolean     @default(false) // visible on Explore
  paymentMethods String[]    @default([]) // ["STRIPE","CASH","BANK_TRANSFER"]

  // Booking settings — null = inherit school defaultBookingSettings
  bookingSettings Json?

  // Weekly schedule: [{ dayOfWeek: 1, startTime: "18:00", endTime: "19:30" }]
  schedule Json?

  instructorId String?
  instructor   Instructor? @relation(fields: [instructorId], references: [id])

  bookings Booking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("classes")
}

// ─────────────────────────────────────────────────────────────────────────────
// EVENT
// One-off events: seminars, competitions, open mats, social events
// ─────────────────────────────────────────────────────────────────────────────

model Event {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  title          String
  slug           String? // public URL segment — /school/[slug]/events/[slug], unique per school
  description    String?
  type           EventType @default(OTHER)
  location       String?
  startAt        DateTime
  endAt          DateTime?
  capacity       Int?
  coverUrl       String?
  gallery        String[]  @default([]) // extra photos shown on the event's own page, beyond the banner
  isPublished    Boolean   @default(false)
  isCancelled    Boolean   @default(false)
  externalUrl    String?
  paymentMethods String[]  @default([]) // ["STRIPE","CASH","BANK_TRANSFER"]

  instructorId String?
  instructor   Instructor?    @relation(fields: [instructorId], references: [id])
  tickets      EventTicket[]
  bookings     EventBooking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, slug])
  @@map("events")
}

model EventTicket {
  id      String @id @default(cuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  name          String // e.g. "Early Bird", "Member", "VIP"
  description   String?
  price         Float   @default(0)
  currency      String  @default("EUR")
  capacity      Int? // null = unlimited
  sortOrder     Int     @default(0)
  stripePriceId String? // wired when Stripe is connected

  bookings EventBooking[]

  createdAt DateTime @default(now())

  @@map("event_tickets")
}

// ─────────────────────────────────────────────────────────────────────────────
// EVENT BOOKING
// A student's paid registration for a ticket type on a one-off Event
// (seminars, competitions, etc). Mirrors CampBooking's shape.
// ─────────────────────────────────────────────────────────────────────────────

model EventBooking {
  id       String      @id @default(cuid())
  eventId  String
  event    Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  ticketId String
  ticket   EventTicket @relation(fields: [ticketId], references: [id])
  userId   String
  user     User        @relation(fields: [userId], references: [id])

  ticketName      String // snapshot — ticket row may be edited/deleted later
  quantity        Int           @default(1)
  status          BookingStatus @default(PENDING)
  amountPaid      Float?
  currency        String        @default("EUR")
  paymentMethod   PaymentMethod @default(STRIPE)
  stripePaymentId String?
  revolutOrderId  String?
  qrToken         String?       @unique
  checkedIn       Boolean       @default(false)
  checkedInAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([eventId, status])
  @@map("event_bookings")
}

// ─────────────────────────────────────────────────────────────────────────────
// BOOKING
// A student's reservation for a specific class occurrence.
// attendedAt = check-in timestamp (null = not yet / no-show)
// membershipId = which active membership covers this booking
// ─────────────────────────────────────────────────────────────────────────────

model Booking {
  id      String @id @default(cuid())
  userId  String
  user    User   @relation(fields: [userId], references: [id])
  classId String
  class   Class  @relation(fields: [classId], references: [id])

  // Which membership covers this booking (optional: drop-ins can be paid directly)
  membershipId String?
  membership   Membership? @relation(fields: [membershipId], references: [id])

  scheduledAt     DateTime
  attendedAt      DateTime? // null = pending / no-show; set = checked in
  status          BookingStatus @default(PENDING)
  paymentMethod   PaymentMethod @default(STRIPE)
  amountPaid      Float?
  currency        String        @default("EUR")
  stripePaymentId String?
  notes           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, attendedAt])
  @@index([userId, scheduledAt])
  @@index([classId, scheduledAt])
  @@map("bookings")
}

// ─────────────────────────────────────────────────────────────────────────────
// MEMBERSHIP
// A student's active subscription at a school.
// classesUsed tracks consumption for class-limited plans.
// ─────────────────────────────────────────────────────────────────────────────

model Membership {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id])
  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  // Link to the plan that originated this membership (optional for legacy/manual)
  planId String?
  plan   MembershipPlan? @relation(fields: [planId], references: [id])

  planName      String // Denormalised name for display / history
  price         Float
  currency      String           @default("EUR")
  paymentMethod PaymentMethod    @default(STRIPE)
  status        MembershipStatus @default(ACTIVE)
  startDate     DateTime
  endDate       DateTime?

  // Usage tracking — computed from bookings count, but cached here for perf
  classesUsed Int @default(0)

  stripeSubId      String?
  stripeCustomerId String?
  stripeInvoiceId  String?
  revolutOrderId   String? // Revolut order ID for one-time and recurring payments
  notes            String?

  // Renewal chain — points to the membership this one renewed/replaced
  renewedFromId String?
  renewedFrom   Membership?  @relation("MembershipRenewal", fields: [renewedFromId], references: [id])
  renewals      Membership[] @relation("MembershipRenewal")

  // Soft cancel timestamp (status=CANCELLED set at same time)
  cancelledAt DateTime?

  // Content platform access granted by this membership
  contentAccess ContentAccess?

  bookings     Booking[]
  transactions Transaction[] @relation("MembershipTransactions")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("memberships")
}

// ─────────────────────────────────────────────────────────────────────────────
// CAMP  (Martial Camps — multi-day training camps)
// ─────────────────────────────────────────────────────────────────────────────

model Camp {
  id       String  @id @default(cuid())
  schoolId String?
  school   School? @relation(fields: [schoolId], references: [id])

  name        String
  description String?
  location    String?
  country     String?
  startDate   DateTime
  endDate     DateTime
  capacity    Int?
  price       Float
  currency    String   @default("EUR")
  coverUrl    String?
  isPublished Boolean  @default(false)

  // Instructors as JSON (may include external guests)
  instructors Json?

  bookings CampBooking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("camps")
}

model CampBooking {
  id              String        @id @default(cuid())
  campId          String
  camp            Camp          @relation(fields: [campId], references: [id])
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  status          BookingStatus @default(PENDING)
  amountPaid      Float?
  currency        String        @default("EUR")
  stripePaymentId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("camp_bookings")
}

// ─────────────────────────────────────────────────────────────────────────────
// SCHOOL MEMBER
// Student/instructor relationship with a school.
// Tracks belt rank, emergency contact, medical info.
// ─────────────────────────────────────────────────────────────────────────────

model SchoolMember {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  role     SchoolMemberRole   @default(STUDENT)
  status   SchoolMemberStatus @default(PENDING)
  joinedAt DateTime?

  // Belt / rank (current)
  belt       String? // "White Belt", "Blue Belt", "Purple Belt" — source of truth for display/history
  beltRankId String? // enrichment FK into the school's structured BeltRank catalog, may be null
  beltRank   BeltRank? @relation(fields: [beltRankId], references: [id], onDelete: SetNull)
  beltDegree Int? // stripes/degrees: 0–4
  beltDate   DateTime? // date current belt was awarded

  // Emergency & medical
  emergencyContact String? // "María García — +34 666 123 456"
  medicalNotes     String? // "Right knee injury, penicillin allergy"

  notes String? // Internal school notes

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, userId])
  @@map("school_members")
}

// ─────────────────────────────────────────────────────────────────────────────
// SCHOOL CLAIM
// ─────────────────────────────────────────────────────────────────────────────

model SchoolClaim {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation(fields: [userId], references: [id])

  status     ClaimStatus @default(PENDING)
  evidence   String?
  notes      String?
  reviewedBy String?
  reviewedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("school_claims")
}

// ─────────────────────────────────────────────────────────────────────────────
// GRADING
// ─────────────────────────────────────────────────────────────────────────────
// GRADING SYSTEM + BELT RANKS
// Each school can have multiple grading systems (one per activity/discipline).
// ─────────────────────────────────────────────────────────────────────────────

model GradingSystem {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  name      String // "BJJ Adultos", "Judo All Ages"
  activity  String? // free text: "BJJ", "Judo", "Karate" — matches Class.type if set
  isDefault Boolean @default(false)
  isActive  Boolean @default(true)

  // Global rules for this system
  requireApproval  Boolean @default(true)
  gradingFee       Int     @default(0) // in cents
  notifyStudent    Boolean @default(true)
  notifyInstructor Boolean @default(true)

  ranks BeltRank[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("grading_systems")
}

model BeltRank {
  id       String        @id @default(cuid())
  systemId String
  system   GradingSystem @relation(fields: [systemId], references: [id], onDelete: Cascade)

  order Int // 0-based position in progression
  name  String // "Blanco", "Azul", "1er Dan"
  color String @default("#9CA3AF") // hex color

  // Stripes / degrees within this rank
  maxDegrees Int @default(0) // 0 = no stripes, 4 = up to 4 stripes

  // Requirements to REACH this rank
  minAge               Int? // minimum age
  minMonthsAtPrevious  Int? // months at previous rank before eligible
  totalClassesRequired Int? // total class count required
  classesPerPeriod     Int? // min classes per period
  periodType           String? // "WEEK" | "MONTH"
  classTypeIds         String[] // which class types count (empty = all)
  requireCompetition   Boolean  @default(false) // must have competed
  requireExam          Boolean  @default(false) // must pass an exam

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members      SchoolMember[]
  gradingsFrom Grading[]      @relation("GradingFromRank")
  gradingsTo   Grading[]      @relation("GradingToRank")

  @@map("belt_ranks")
}

// Belt promotion records. Maps V1 promote_students + studnet_grading_notes.
// ─────────────────────────────────────────────────────────────────────────────

model Grading {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation("GradingStudent", fields: [userId], references: [id])

  promotedById String?
  promotedBy   User?   @relation("GradingPromoter", fields: [promotedById], references: [id])

  fromBelt       String? // "White Belt" — source of truth for display/history
  fromBeltRankId String? // enrichment FK, may be null
  fromBeltRank   BeltRank? @relation("GradingFromRank", fields: [fromBeltRankId], references: [id], onDelete: SetNull)
  toBelt         String // "Blue Belt" — source of truth for display/history
  toBeltRankId   String? // enrichment FK, may be null
  toBeltRank     BeltRank? @relation("GradingToRank", fields: [toBeltRankId], references: [id], onDelete: SetNull)
  toDegree       Int? // 0 = plain belt, 1–4 = stripes/degrees
  gradedAt       DateTime
  notes          String?
  isPublic       Boolean   @default(true) // show on student profile

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("gradings")
}

// ─────────────────────────────────────────────────────────────────────────────
// LEAD + LEAD NOTE
// Prospective students. Maps V1 leads (865 rows) + lead_notes (36 rows).
// ─────────────────────────────────────────────────────────────────────────────

model Lead {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  name         String
  email        String?
  phone        String?
  source       LeadSource @default(OTHER)
  status       LeadStatus @default(NEW)
  message      String? // Initial enquiry message
  interestedIn String? // "BJJ Adults", "Kids Class", "Private Lessons"

  // If they converted to a member
  convertedUserId String?
  convertedUser   User?     @relation("LeadConvertedUser", fields: [convertedUserId], references: [id])
  convertedAt     DateTime?

  notes LeadNote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("leads")
}

model LeadNote {
  id       String @id @default(cuid())
  leadId   String
  lead     Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  text      String
  createdAt DateTime @default(now())

  @@map("lead_notes")
}

// ─────────────────────────────────────────────────────────────────────────────
// SCHOOL INVITATION
// Admin-initiated invite to onboard a new school onto the platform.
// ─────────────────────────────────────────────────────────────────────────────

enum InvitationStatus {
  PENDING // Created, email not yet sent
  SENT // Invite email sent
  OPENED // Link clicked
  REGISTERED // School completed onboarding → School record created
  DECLINED // School declined or unsubscribed
}

enum InvitationSource {
  MANUAL // Admin typed name + email
  IMPORT // Bulk CSV/Excel import
}

model SchoolInvitation {
  id    String @id @default(cuid())
  token String @unique @default(cuid())

  // Basic info (filled by admin or from import)
  name       String
  email      String
  phone      String?
  city       String?
  country    String?
  activities String? // "BJJ, Grappling, MMA"
  website    String?
  notes      String?

  status InvitationStatus @default(PENDING)
  source InvitationSource @default(MANUAL)

  // Admin who created the invite
  invitedById String?
  invitedBy   User?   @relation("InvitedByUser", fields: [invitedById], references: [id])

  // School created after successful onboarding
  // Not unique — allows re-inviting after decline/expiry
  schoolId String?
  school   School? @relation(fields: [schoolId], references: [id])

  // Only one invitation per school should be active at a time
  isActive Boolean @default(true)

  sentAt       DateTime?
  openedAt     DateTime?
  registeredAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId, isActive])
  @@map("school_invitations")
}

// ─────────────────────────────────────────────────────────────────────────────
// WAIVER + USER WAIVER
// Legal agreements. Maps V1 user_waivers (48 rows).
// ─────────────────────────────────────────────────────────────────────────────

model Waiver {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  title    String // "Liability Waiver & Informed Consent"
  content  String // HTML or Markdown legal text
  version  String  @default("1.0")
  isActive Boolean @default(true)

  signedBy UserWaiver[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("waivers")
}

model UserWaiver {
  id       String @id @default(cuid())
  waiverId String
  waiver   Waiver @relation(fields: [waiverId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation(fields: [userId], references: [id])

  signedAt  DateTime @default(now())
  ipAddress String?
  signature String? // base64 or typed name

  @@unique([waiverId, userId])
  @@map("user_waivers")
}

// ─────────────────────────────────────────────────────────────────────────────
// LOGIN HISTORY
// Audit log of login events (IP, geolocation, device). Not a live-session
// table — Supabase's own auth.sessions is ephemeral and gets pruned, so this
// is the durable record. Snapshot fields preserve the user's identity/role at
// the time of login even if the User is later deleted or changed.
// ─────────────────────────────────────────────────────────────────────────────

model LoginHistory {
  id String @id @default(cuid())

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Snapshot of the user at login time (survives deletion / role changes)
  userEmail String?
  userName  String?
  userRole  Role?

  ipAddress String?
  country   String?
  city      String?

  userAgent String? // full raw string, kept as fallback
  browser   String?
  os        String?
  device    String? // 'Desktop' | 'Mobile' | 'Tablet' | 'Unknown'

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userEmail])
  @@index([createdAt])
  @@index([userId, ipAddress, createdAt])
  @@map("login_history")
}

// Audit trail for superadmin "log in as owner" impersonation. Written for
// every attempt (success or failure) — the impersonate route must not return
// a login link unless this write succeeds first.
model ImpersonationLog {
  id String @id @default(cuid())

  actorId    String?
  actor      User?   @relation("ImpersonationActor", fields: [actorId], references: [id], onDelete: SetNull)
  actorEmail String

  targetUserId String?
  target       User?   @relation("ImpersonationTarget", fields: [targetUserId], references: [id], onDelete: SetNull)
  targetEmail  String?

  schoolId String?
  school   School? @relation(fields: [schoolId], references: [id], onDelete: SetNull)

  ipAddress String?
  userAgent String?
  reason    String?

  success      Boolean
  errorMessage String?

  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([targetUserId])
  @@index([schoolId])
  @@index([createdAt])
  @@map("impersonation_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// TRANSACTION
// School financial records: income + expenses in one table.
// Maps V1 expenses (119) + incomes (6) + orders (43).
// ─────────────────────────────────────────────────────────────────────────────

model Transaction {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  type          TransactionType
  status        TransactionStatus   @default(PAID)
  category      TransactionCategory @default(OTHER)
  paymentMethod PaymentMethod?
  amount        Float
  currency      String              @default("EUR")
  description   String?
  date          DateTime

  // Optional links to source record
  membershipId String?
  membership   Membership? @relation("MembershipTransactions", fields: [membershipId], references: [id])
  bookingId    String?
  userId       String?
  user         User?       @relation("TransactionUser", fields: [userId], references: [id])

  // Provider reconciliation references — set on the online-payment transactions
  // created by the Stripe/Revolut webhook handlers so each row can be traced
  // back to the corresponding record in the provider's dashboard.
  stripePaymentIntentId String?
  stripeInvoiceId       String? // set for subscription-renewal transactions
  revolutOrderId        String?

  notes       String?
  periodStart DateTime?
  periodEnd   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stripePaymentIntentId])
  @@index([revolutOrderId])
  @@map("transactions")
}

// ─────────────────────────────────────────────────────────────────────────────
// USER PREFERENCE
// Stores last selected context for school picker. Not an authorization source.
// Authorization always comes from SchoolMember.
// ─────────────────────────────────────────────────────────────────────────────

model UserPreference {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Last active school context — suggestion only, not authorization
  lastSchoolId    String?
  lastContextType String? // "SCHOOL" | "PERSONAL" | "ADMIN"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_preferences")
}

// ─────────────────────────────────────────────────────────────────────────────
// STORE  (Phase future — schema defined, not connected yet)
// Maps V1 products (15) + orders (43)
// ─────────────────────────────────────────────────────────────────────────────

model ProductCategory {
  id       String @id @default(cuid())
  schoolId String
  name     String
  slug     String

  products Product[]

  @@unique([schoolId, slug])
  @@map("product_categories")
}

model Product {
  id         String           @id @default(cuid())
  schoolId   String
  categoryId String?
  category   ProductCategory? @relation(fields: [categoryId], references: [id])

  name        String
  description String?
  price       Float
  currency    String  @default("EUR")
  stock       Int? // null = unlimited (e.g. digital products)
  imageUrl    String?
  isActive    Boolean @default(true)

  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("products")
}

model Order {
  id       String @id @default(cuid())
  schoolId String
  userId   String

  status   String @default("PENDING") // PENDING | PAID | CANCELLED | REFUNDED
  total    Float
  currency String @default("EUR")

  stripePaymentIntentId String?

  items OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("orders")
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])

  quantity  Int
  unitPrice Float
  currency  String @default("EUR")

  @@map("order_items")
}

// ─────────────────────────────────────────────────────────────────────────────
// PARTNER  (Brand ambassadors: Roger Gracie the person, Buchecha, etc.)
// Different from Affiliation (the organization)
// ─────────────────────────────────────────────────────────────────────────────

model Partner {
  id        String  @id @default(cuid())
  name      String // "Roger Gracie", "Marcus Almeida Buchecha"
  slug      String  @unique
  title     String? // "10x World Champion"
  bio       String?
  photoUrl  String?
  instagram String?
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("partners")
}

// ─────────────────────────────────────────────────────────────────────────────
// NOTIFICATION  (in-app notifications for school admins)
// ─────────────────────────────────────────────────────────────────────────────

enum NotificationType {
  NEW_LEAD
  NEW_MEMBER
  PAYMENT_RECEIVED
  PAYMENT_PENDING
  MEMBERSHIP_REQUEST
  MEMBERSHIP_EXPIRING
  CLASS_FULL
  CLASS_CANCELLED
  GRADING_COMPLETED
  STUDENT_INACTIVE
  MESSAGE
}

model Notification {
  id       String           @id @default(cuid())
  schoolId String
  school   School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  type     NotificationType
  title    String
  body     String
  href     String? // deep-link to the relevant page
  read     Boolean          @default(false)

  // Null = school-wide (visible to any staff member with dashboard access to this
  // school). Set = only the targeted user should see it (e.g. a direct message
  // aimed at one specific staff member), on top of anyone with school access.
  recipientUserId String?
  recipientUser   User?   @relation(fields: [recipientUserId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([schoolId, read])
  @@index([schoolId, createdAt])
  @@index([recipientUserId])
  @@map("notifications")
}

// ─────────────────────────────────────────────────────────────────────────────
// PLATFORM SETTINGS  (super admin — single row, id is fixed to "singleton")
// Two distinct concerns live here on purpose:
//  1. enabledPaymentMethods — gates which methods schools may offer *their*
//     members (schools then pick their own subset in School.defaultBookingSettings).
//  2. plan* / stripePriceId* — Martial's own SaaS plan that schools subscribe
//     to (see SchoolSubscription below), billed on Martial's platform Stripe
//     account, unrelated to any school's own Stripe keys.
// ─────────────────────────────────────────────────────────────────────────────

model PlatformSettings {
  id                    String   @id @default("singleton")
  enabledPaymentMethods String[] @default(["STRIPE", "REVOLUT", "CASH", "BANK_TRANSFER", "DIRECT_DEBIT", "PAYPAL", "OTHER"])

  defaultCurrency  String  @default("EUR")
  defaultTaxName   String?
  defaultTaxRate   Float?
  defaultTaxNumber String?
  taxActive        Boolean @default(false)

  // Days a school may remain PAST_DUE before manual admin intervention.
  // No automated enforcement yet — see SchoolSubscription below.
  gracePeriodDays Int @default(0)

  // Derived from Stripe at save time (see /api/admin/settings/payments) —
  // never typed directly by the admin, to avoid the displayed price
  // drifting from what the Stripe Price actually charges.
  planCurrency           String  @default("EUR")
  planPriceMonthly       Int?
  planPriceQuarterly     Int?
  planPriceAnnual        Int?
  stripePriceIdMonthly   String?
  stripePriceIdQuarterly String?
  stripePriceIdAnnual    String?

  // Notifications — emailed to superAdminEmail below
  notifyNewSchool       Boolean @default(true)
  notifyVerificationReq Boolean @default(true)
  notifyWeeklyReport    Boolean @default(false)

  // Platform toggles
  allowSelfRegistration    Boolean @default(true)
  requireEmailVerification Boolean @default(true)
  // Persisted flag only — no enforcement (middleware gating) exists yet.
  maintenanceMode          Boolean @default(false)

  // Security / contact
  superAdminEmail String? @default("admin@martial.app")
  supportEmail    String? @default("hello@martial.app")

  // Email
  emailSenderName String @default("Martial")

  updatedAt DateTime @updatedAt

  @@map("platform_settings")
}

model SchoolSubscription {
  id       String @id @default(cuid())
  schoolId String @unique
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  billingCycle String? // 'monthly' | 'quarterly' | 'annual' — matches MembershipPlan.billingCycle convention

  status SchoolSubscriptionStatus @default(INACTIVE)

  stripeCustomerId     String?
  stripeSubscriptionId String?
  currentPeriodEnd     DateTime?
  trialEndsAt          DateTime?
  cancelledAt          DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("school_subscriptions")
}

// Webhook idempotency for the platform Stripe webhook (and reusable for the
// per-school one). Starts PROCESSING and only flips to PROCESSED once the
// handler fully completes — a crash mid-handler leaves it PROCESSING/FAILED
// so a Stripe retry is treated as a recovery attempt, not a duplicate.
model StripeWebhookEvent {
  id          String                   @id @default(cuid())
  eventId     String                   @unique
  type        String
  status      StripeWebhookEventStatus @default(PROCESSING)
  processedAt DateTime?
  error       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("stripe_webhook_events")
}
