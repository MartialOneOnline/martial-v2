{
  "name": "martial-v2",
  "private": true,
  "scripts": {
    "build": "npx turbo run build --filter=web && cp -r apps/web/.next .next && cp apps/web/next.config.js next.config.js && cp -r apps/web/public public",
    "start": "node_modules/.bin/next start",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "dependencies": {
    "next": "16.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "prisma": "^7.8.0",
    "turbo": "^2.9.15",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.13.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
